# Copy this file to `.env` and fill in the values. `.env` is gitignored and is
# loaded automatically by mise (see mise.toml [settings] env_file = ".env").
#
#   cp .env.example .env

# ── GitOps source (required) ──────────────────────────────────────────────────
# HTTPS URL of THIS repository. Flux syncs the capi-mgmt/ path from here.
GIT_REPO_URL="https://github.com/polarsquad/knr-ops"

# ── GitHub PAT for Flux (required) ────────────────────────────────────────────
# Create a fine-grained personal access token with read-only Contents access
# to this repository (a classic token with `repo` scope also works).
GITHUB_TOKEN=""
# Basic-auth username paired with the token. Any non-empty value works for
# GitHub PATs; "git" is a safe default.
GITHUB_USER="git"

# ── SOPS age key (required) ───────────────────────────────────────────────────
# Path to the age PRIVATE key used by Flux to decrypt *.sops.yaml secrets.
# Generate one with `mise run sops-keygen` (creates ./age.agekey, gitignored).
AGE_KEY_FILE="age.agekey"

# ── AWS credentials for CAPA (optional, for clusterawsadm) ────────────────────
# AWS credentials are NOT set here. They live SOPS-encrypted in Git at
# capi-mgmt/capi-providers/capa-system/aws-credentials.sops.yaml and are
# decrypted in-cluster by Flux. To set/rotate them:
#
#   1. Run: mise run aws-bootstrap     (provisions IAM via CloudFormation)
#   2. Run: mise run aws-credentials   (exports profile to .sops.yaml)
#   3. Run: mise run sops-encrypt capi-mgmt/capi-providers/capa-system/aws-credentials.sops.yaml
#
# AWS_REGION can be overridden here (default: eu-north-1):
# AWS_REGION="eu-west-1"

# ── Notes ─────────────────────────────────────────────────────────────────────
# • NEVER commit .env, *.agekey, or any file containing real secrets
# • The .setup/ directory contains template keys from demos — remove before prod
# • If you see "SOPS decryption failed" in Flux, verify:
#     1. age.agekey public key matches the one in .sops.yaml
#     2. The sops-age secret exists in flux-system namespace
#     3. aws-credentials.sops.yaml is actually encrypted (not plaintext)
